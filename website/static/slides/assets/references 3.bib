@article{goliFrontiersCanLarge2024,
  title = {Frontiers: {{Can Large Language Models Capture Human Preferences}}?},
  shorttitle = {Frontiers},
  author = {Goli, Ali and Singh, Amandeep},
  year = 2024,
  month = jul,
  journal = {Marketing Science},
  volume = {43},
